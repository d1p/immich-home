# Documentation: https://immich.app/docs/install/environment-variables
# Copy this file to .env and fill in your values before starting Immich.

# -----------------------------------------------------------------------------
# Core paths
# -----------------------------------------------------------------------------
UPLOAD_LOCATION=./library
DB_DATA_LOCATION=./postgres

# -----------------------------------------------------------------------------
# Version — pin to a specific release for stability (recommended).
# To upgrade: change the version, then run: docker compose pull && docker compose up -d
# Releases: https://github.com/immich-app/immich/releases
# -----------------------------------------------------------------------------
IMMICH_VERSION=v2.6.3

# Timezone — see https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=Etc/UTC

# -----------------------------------------------------------------------------
# Database credentials — use only A-Za-z0-9, no special characters or spaces
# -----------------------------------------------------------------------------
DB_PASSWORD=CHANGE_ME_use_a_32char_random_string
DB_USERNAME=immich
DB_DATABASE_NAME=immich

# -----------------------------------------------------------------------------
# Amazon S3 Glacier Deep Archive backup
# Create IAM user with s3:PutObject/GetObject/ListBucket/DeleteObject on your bucket.
# -----------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=your-iam-access-key-id
AWS_SECRET_ACCESS_KEY=your-iam-secret-access-key
S3_BUCKET_NAME=your-glacier-bucket-name
S3_REGION=us-east-1